# KMS mode: "local" (no AWS needed) or "aws" (real AWS KMS)
KMS_MODE=local

# Local KMS paths
LOCAL_KMS_STORE_PATH=./data/kms_store.json
LOCAL_KMS_MASTER_KEY_PATH=./data/master.key

# Storage mode: "local" (filesystem) or "s3" (real S3 / LocalStack)
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./data/records

# When using real AWS / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
KMS_ENDPOINT_URL=http://localhost:4566
S3_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=encrypted-pii-records

# Key registry
KEY_REGISTRY_PATH=./data/key_registry.json

# Rotation settings
ROTATION_BATCH_SIZE=50
DUAL_READ_WINDOW_SECONDS=30
