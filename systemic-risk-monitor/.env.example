# Copy to .env and adjust as needed

MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687

# Number of synthetic institutions in the interbank network
NUM_INSTITUTIONS=20

# Transaction ingestion rate (milliseconds between transactions)
TRANSACTION_INTERVAL_MS=200

# API server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Risk thresholds (optional overrides)
# CONCENTRATION_HHI_THRESHOLD=0.25
# BETWEENNESS_THRESHOLD=0.35
# LIQUIDITY_SHOCK_PCT=0.30
# CONTAGION_CASCADE_THRESHOLD=0.50
