# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SERVING_TOPIC=serving_requests
KAFKA_DRIFT_TOPIC=drift_alerts
KAFKA_RETRAIN_TOPIC=retrain_triggers
KAFKA_CONSUMER_GROUP=mlops_data_layer

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mlops:mlops_pass@localhost:5432/mlops

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Feature store ─────────────────────────────────────────────────────────────
FEATURE_DEFINITIONS_PATH=config/features/feature_definitions.yml
FEATURE_STORE_WINDOW_DAYS=30

# ── Drift detection ───────────────────────────────────────────────────────────
DRIFT_EVAL_WINDOW_SIZE=500
DRIFT_EVAL_INTERVAL_SECONDS=300
KS_PVALUE_THRESHOLD=0.05
PSI_THRESHOLD=0.2
JS_THRESHOLD=0.1

# ── Skew detection ────────────────────────────────────────────────────────────
SKEW_PSI_THRESHOLD=0.1

# ── Retraining ────────────────────────────────────────────────────────────────
RETRAIN_COOLDOWN_SECONDS=3600
RETRAIN_MIN_DRIFT_FEATURES=2
# RETRAIN_WEBHOOK_URL=https://your-ml-platform/api/retrain

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json    # json | console
