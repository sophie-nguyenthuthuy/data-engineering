# Copy to .env and fill in values

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=feature-events
CONSUMER_GROUP_ID=feature-store-consumer

# Redis
REDIS_URL=redis://localhost:6379

# Offline store
OFFLINE_STORE_PATH=./data/offline

# Serving
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
L1_CACHE_TTL_SECONDS=1

# Config
CONFIG_PATH=configs/feature_store.yaml
