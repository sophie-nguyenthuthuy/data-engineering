# ── Hot tier ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/tiered_storage

# ── Warm tier (S3) ────────────────────────────────────────────────────────
S3_BUCKET=tiered-storage-warm
S3_WARM_PREFIX=warm
AWS_REGION=us-east-1

# AWS credentials (leave blank when using IAM roles or LocalStack)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LocalStack / MinIO endpoint (comment out for real AWS)
S3_ENDPOINT_URL=http://localhost:4566

# ── Cold tier ─────────────────────────────────────────────────────────────
S3_COLD_PREFIX=cold

# Use a local folder instead of S3 for cold tier (great for dev/testing)
COLD_LOCAL_PATH=./data/cold

# Set to true to write cold objects with S3 GLACIER storage class
USE_GLACIER=false

# ── Lifecycle policy ──────────────────────────────────────────────────────
LIFECYCLE_INTERVAL_SECONDS=3600   # run every hour
HOT_TO_WARM_IDLE_DAYS=7           # demote hot→warm after 7 days idle
WARM_TO_COLD_IDLE_DAYS=30         # demote warm→cold after 30 days idle
HOT_MAX_SIZE_GB=10                # force-demote when hot exceeds 10 GB
WARM_MAX_SIZE_GB=500              # force-demote when warm exceeds 500 GB
HOT_MIN_ACCESS_FREQ=1.0           # demote if EMA freq < 1 access/day

# ── Rehydration ───────────────────────────────────────────────────────────
REHYDRATION_PRIORITY=standard     # expedited | standard | bulk
PROMOTE_FREQ_THRESHOLD=5.0        # promote warm→hot if freq > 5/day
BLOCK_ON_COLD=false               # if true, GET waits for cold restore

# ── Access tracker ────────────────────────────────────────────────────────
TRACKER_PERSIST_PATH=./data/tracker.json
