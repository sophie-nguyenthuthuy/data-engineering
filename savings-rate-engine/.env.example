# Database — defaults to SQLite, swap for Postgres in production
DATABASE_URL=sqlite:///./data/rates.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/rates_db

# Scraping
REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRY_ATTEMPTS=3
USE_MOCK_DATA=false          # set true to skip live scraping (useful in CI/testing)
SCRAPE_INTERVAL_HOURS=6      # how often the scheduler fires
USER_AGENT=SavingsRateEngine/0.1 (+https://github.com/YOUR_USERNAME/savings-rate-engine)

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Logging
LOG_LEVEL=INFO
