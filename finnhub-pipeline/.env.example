# Finnhub API. Leave blank to run in DEMO mode (synthetic trades).
FINNHUB_API_KEY=

# Comma-separated tickers to subscribe to.
SYMBOLS=BINANCE:BTCUSDT,BINANCE:ETHUSDT,AAPL,TSLA,NVDA

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
TRADES_TOPIC=trades
AGGREGATES_TOPIC=trades.agg.5s

# Postgres / TimescaleDB
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline
POSTGRES_DB=market
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# API
API_PORT=8000

# Frontend (served by nginx)
WEB_PORT=3000
