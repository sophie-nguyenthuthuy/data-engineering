# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=raw_data_batches
KAFKA_RESULTS_TOPIC=quality_results
KAFKA_CONSUMER_GROUP=dq_monitor

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dqm:dqm_pass@localhost:5432/dqmonitor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Validation ────────────────────────────────────────────────────────────────
VALIDATOR_BACKEND=both           # great_expectations | soda | both
FAILURE_THRESHOLD=0.95           # min pass rate before blocking (0.0–1.0)

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json | console
