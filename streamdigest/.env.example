# --- Primary source: GitHub ---
# Personal access token (classic) with `notifications` + `repo` scopes,
# or a fine-grained token with Notifications: read.
GITHUB_TOKEN=ghp_xxx

# --- Local LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Storage ---
DUCKDB_PATH=./data/streamdigest.duckdb

# --- Optional alt sources (stubs) ---
# GMAIL_HOST=imap.gmail.com
# GMAIL_EMAIL=
# GMAIL_APP_PASSWORD=
# SLACK_BOT_TOKEN=
# LINEAR_API_KEY=
