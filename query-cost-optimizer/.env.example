# --- BigQuery ---
BQ_PROJECT_ID=your-gcp-project
# Path to a GCP service account JSON key (optional if using ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json

# How many days of INFORMATION_SCHEMA query history to pull
BQ_HISTORY_DAYS=30

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
# Or use key-pair auth:
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=SNOWFLAKE
SNOWFLAKE_SCHEMA=ACCOUNT_USAGE
SF_HISTORY_DAYS=30

# --- Optimizer thresholds ---
# Minimum estimated monthly savings (USD) to surface a recommendation
MIN_SAVINGS_USD=10
# Minimum number of times a pattern must appear before it's flagged
MIN_QUERY_COUNT=5
