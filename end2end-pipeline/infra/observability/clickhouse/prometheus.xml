<!-- ClickHouse Prometheus endpoint. Mounted into
     /etc/clickhouse-server/config.d/prometheus.xml so it merges with the
     default server config without editing upstream files. -->
<clickhouse>
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <status_info>true</status_info>
    </prometheus>
</clickhouse>
