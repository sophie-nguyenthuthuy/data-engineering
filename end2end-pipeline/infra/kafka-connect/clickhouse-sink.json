{
  "name": "clickhouse-sink",
  "config": {
    "connector.class": "com.clickhouse.kafka.connect.ClickHouseSinkConnector",
    "tasks.max": "2",
    "topics": "${env:KAFKA_TOPIC}",

    "hostname": "${env:CLICKHOUSE_HOST}",
    "port": "${env:CLICKHOUSE_PORT_HTTP}",
    "database": "${env:CLICKHOUSE_DB}",
    "username": "${env:CLICKHOUSE_USER}",
    "password": "${env:CLICKHOUSE_PASSWORD}",
    "ssl": "false",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "${env:SCHEMA_REGISTRY_URL_INTERNAL}",
    "value.converter.schemas.enable": "true",

    "exactlyOnce": "false",
    "schemas.enable": "true",

    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "errors.retry.timeout": "300000",
    "errors.retry.delay.max.ms": "30000",
    "errors.deadletterqueue.topic.name": "${env:KAFKA_DLQ_TOPIC}",
    "errors.deadletterqueue.topic.replication.factor": "1",
    "errors.deadletterqueue.context.headers.enable": "true"
  }
}
