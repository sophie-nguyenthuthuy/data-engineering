# Copy to .env and adjust. .env is gitignored.

# Kafka
KAFKA_BROKERS_INTERNAL=kafka:9092
KAFKA_BROKERS_EXTERNAL=localhost:19092
KAFKA_TOPIC=user-interactions
KAFKA_DLQ_TOPIC=user-interactions-dlq
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Schema Registry
SCHEMA_REGISTRY_URL_INTERNAL=http://schema-registry:8081
SCHEMA_REGISTRY_URL_EXTERNAL=http://localhost:8081

# Kafka Connect
CONNECT_URL_INTERNAL=http://kafka-connect:8083
CONNECT_URL_EXTERNAL=http://localhost:8083

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT_HTTP=8123
CLICKHOUSE_PORT_NATIVE=9000
CLICKHOUSE_DB=events
CLICKHOUSE_USER=pipeline
CLICKHOUSE_PASSWORD=change_me_in_env
CLICKHOUSE_TABLE=user_interactions

# Producer
PRODUCER_EVENTS_PER_SEC=50
PRODUCER_ERROR_RATE=0.05

# API
API_PORT=8000

# Dashboard
DASHBOARD_PORT=8501

# --- Phase 4 (orchestration) ---------------------------------------------
# MinIO (S3-compatible object store for the Parquet slices Dagster writes).
# Host port 9100 because ClickHouse native protocol already owns 9000 on the host.
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=pipeline
MINIO_ROOT_PASSWORD=miniodev_change_me
S3_BUCKET=pipeline

# Dagster webserver port.
DAGSTER_PORT=3000

# --- Phase 5 (observability) ----------------------------------------------
# Host-side ports. Use 3001 for Grafana because Dagster holds 3000.
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
TEMPO_HTTP_PORT=3200
OTEL_OTLP_GRPC_PORT=4317
OTEL_OTLP_HTTP_PORT=4318
# Dev-stack only: secure stack reads this from a Docker secret.
GRAFANA_ADMIN_PASSWORD=admin

# --- Phase 2 (secure) -----------------------------------------------------
# Values here are consumed ONLY by docker-compose.secure.yml and the
# bootstrap script. They never appear in docker-compose.yml (dev).
#
# KAFKA_CLIENT_USERS / KAFKA_CLIENT_PASSWORDS provision SCRAM users on the
# Bitnami Kafka image at first boot. Order matters — it's a zip.
KAFKA_CLIENT_USERS=producer,connect,schemaregistry,admin,api,replay
# Passwords are looked up from secrets/clients/<user>_password at `make up-secure`
# time via make; you do not need to put real passwords here. These placeholders
# are replaced by the Makefile with values from the generated secret files.
KAFKA_CLIENT_PASSWORDS=__FROM_SECRETS__
KAFKA_INTER_BROKER_USER=admin
KAFKA_INTER_BROKER_PASSWORD=__FROM_SECRETS__

